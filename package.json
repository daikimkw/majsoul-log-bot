{
  "name": "majsoul-log-bot",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply majsoul-log --local",
    "db:migrate:remote": "wrangler d1 migrations apply majsoul-log --remote"
  },
  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^3",
    "wrangler": "^4"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
